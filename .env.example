# Runtime mode
ENV=local
LOG_LEVEL=INFO
SIMULATION_MODE=true

# API keys
OPENWEATHER_API_KEY=replace_me
OPENWEATHER_CITY=New York
OPENWEATHER_UNITS=metric
GRIDSTATUS_API_KEY=replace_me_optional
GRIDSTATUS_MARKET=nyiso
GRIDSTATUS_LOCATION=NYC

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_WEATHER=weather-data
KAFKA_TOPIC_ENERGY=energy-prices
KAFKA_TOPIC_PROCESSED=processed-data
KAFKA_TOPIC_SIGNALS=trading-signals
KAFKA_CONSUMER_GROUP=energy-price-pipeline

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=energy_pipeline
POSTGRES_USER=energy_user
POSTGRES_PASSWORD=energy_password
DATABASE_URL=postgresql://energy_user:energy_password@postgres:5432/energy_pipeline

# Model / trading
MODEL_PATH=/app/artifacts/prophet_model.pkl
TRAINING_LOOKBACK_HOURS=720
FORECAST_HORIZON_HOURS=24
BUY_THRESHOLD=3.0
SELL_THRESHOLD=3.0
MAX_POSITION_MWH=10
MAX_DAILY_TRADES=20

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=energy-price-forecasting
